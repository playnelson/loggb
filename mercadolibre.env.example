# === Autocomplete Mercado Livre (única fonte do /api/ml-search) ===
# Copie para .env.local na raiz do projeto (não commitar) ou configure no painel do host (Vercel).

# Opção A — recomendado: app obtém o token sozinho
MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=

# Opção B — token Bearer manual (fluxo com código no DevCenter; ignora A se preenchido)
# MERCADOLIBRE_ACCESS_TOKEN=

# Opcional — padrão MLB (Brasil)
# MERCADOLIBRE_SITE_ID=MLB

# O que estava faltando se der 403 em produção:
# - Variáveis acima NÃO existem no Vercel/host → adicione e faça redeploy.
# - .env.local só vale no PC; reinicie `npm run dev` após editar.
