# Copie para .env.local (não commitar). Opcional: defina só ID+secret OU só ACCESS_TOKEN.

# ID numérico da aplicação (DevCenter)
MERCADOLIBRE_CLIENT_ID=

# Chave secreta da aplicação
MERCADOLIBRE_CLIENT_SECRET=

# Opcional: token Bearer fixo (ignora client_credentials se preenchido)
# MERCADOLIBRE_ACCESS_TOKEN=

# Site da API (padrão MLB = Brasil)
# MERCADOLIBRE_SITE_ID=MLB
